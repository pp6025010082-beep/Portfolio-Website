# Port the Express server listens on
PORT=5000

# MongoDB connection string (MongoDB Atlas recommended for deployment)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/portfolio?retryWrites=true&w=majority

# Comma-separated list of allowed front-end origins for CORS
CLIENT_ORIGIN=http://localhost:5173

# Password required to access the admin dashboard (choose a strong value)
ADMIN_PASSWORD=change-me

# Secret used to sign admin JWT sessions (choose a long random string)
ADMIN_JWT_SECRET=change-me-too
